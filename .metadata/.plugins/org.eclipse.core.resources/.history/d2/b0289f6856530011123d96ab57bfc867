#include <stdio.h>
#include <string.h>

#include "lwip/err.h"
#include "lwip/tcp.h"
#include "xil_printf.h"
#include "xparameters.h"

// CONFIG
#define PORT 5000
#define WIDTH 320
#define HEIGHT 240
#define FRAME_SIZE (WIDTH * HEIGHT * 3)

#define DDR_BASE_ADDR XPAR_DDR_MEM_BASEADDR
// or:
// #define DDR_BASE_ADDR 0x10000000

// Buffers
static unsigned char frame_buffer[FRAME_SIZE];

// State
static int state = 0;
static int frame_size = 0;
static int received = 0;

// Size parsing
static unsigned char size_buf[4];
static int size_index = 0;

//-------------------------------------
err_t recv_callback(void *arg,
                    struct tcp_pcb *tpcb,
                    struct pbuf *p,
                    err_t err)
{
    if (!p)
    {
        tcp_close(tpcb);
        return ERR_OK;
    }

    tcp_recved(tpcb, p->len);

    unsigned char *data = (unsigned char *)p->payload;
    int len = p->len;
    int i = 0;

    while (i < len)
    {
        // ===== RECEIVE SIZE =====
        if (state == 0)
        {
            size_buf[size_index] = data[i];
            size_index++;
            i++;

            if (size_index == 4)
            {
                // ✅ Now definitely used → warning gone
                frame_size =
                    (size_buf[0] << 24) |
                    (size_buf[1] << 16) |
                    (size_buf[2] << 8)  |
                    (size_buf[3]);

                xil_printf("Frame size: %d\r\n", frame_size);

                if (frame_size != FRAME_SIZE)
                {
                    xil_printf("Invalid frame size\r\n");
                    size_index = 0;
                    state = 0;
                    break;
                }

                received = 0;
                size_index = 0;
                state = 1;
            }
        }

        // ===== RECEIVE FRAME =====
        else
        {
            int remaining = FRAME_SIZE - received;
            int copy_len = (len - i < remaining) ? (len - i) : remaining;

            memcpy(frame_buffer + received, data + i, copy_len);

            received += copy_len;
            i += copy_len;

            if (received >= FRAME_SIZE)
            {
                xil_printf("Frame received\r\n");

                memcpy((void *)DDR_BASE_ADDR,
                       frame_buffer,
                       FRAME_SIZE);

                xil_printf("Written to DDR\r\n");

                state = 0;
            }
        }
    }

    pbuf_free(p);
    return ERR_OK;
}

//-------------------------------------
err_t accept_callback(void *arg,
                      struct tcp_pcb *newpcb,
                      err_t err)
{
    xil_printf("Client connected\r\n");
    tcp_recv(newpcb, recv_callback);
    return ERR_OK;
}

//-------------------------------------
int start_application()
{
    struct tcp_pcb *pcb;

    pcb = tcp_new();
    if (!pcb)
        return -1;

    if (tcp_bind(pcb, IP_ADDR_ANY, PORT) != ERR_OK)
        return -2;

    pcb = tcp_listen(pcb);

    tcp_accept(pcb, accept_callback);

    xil_printf("Server started on port %d\r\n", PORT);

    return 0;
}
