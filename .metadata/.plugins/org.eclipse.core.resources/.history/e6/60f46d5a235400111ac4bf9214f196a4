#include "platform.h"
#include "xil_printf.h"

#include "lwip/init.h"
#include "lwip/netif.h"
#include "netif/xadapter.h"

extern struct netif server_netif;
struct netif *netif = &server_netif;

int start_application(void);

int main()
{
    init_platform();

    xil_printf("Starting Ethernet to HDMI app...\r\n");

    lwip_init();

    // Network setup usually already exists in lwIP examples
    // IP address configuration happens here

    start_application();

    while (1)
    {
        xemacif_input(netif);

        transfer_data(); // optional periodic tasks
    }

    cleanup_platform();

    return 0;
}
